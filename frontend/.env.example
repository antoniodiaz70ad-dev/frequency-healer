# Frequency Healer - Variables de Entorno
# Copia este archivo como .env.local para desarrollo local

# URL pública de la app (usado para Open Graph y canonical URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre de la app
NEXT_PUBLIC_APP_NAME=Frequency Healer

# ID de analytics (opcional - dejar vacío para desactivar)
NEXT_PUBLIC_ANALYTICS_ID=
